# Copy this file to ".env" and fill in real values. NEVER commit the real .env file.

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# MongoDB connection string.
# Local install:  mongodb://localhost:27017
# MongoDB Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=stress_tracker

# JWT settings
JWT_SECRET=change-me-to-another-long-random-string
JWT_EXPIRES_HOURS=24

# Where the React frontend runs (for CORS)
FRONTEND_ORIGIN=http://localhost:5173
